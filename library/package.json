{
  "name": "@mahatisystems/mahati-ui-components",
  "version": "6.1.2",
  "description": "Mahati Systems UI Component Library",
  "author": "Mahati Systems <info@mahatisystems.com> (https://www.mahatisystems.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanjeet-mahati/mahati-ui.git"
  },
  "homepage": "https://www.mahatisystems.com",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:css": "postcss src/styles/index.css -o dist/styles.css",
    "build": "npm run build:css && tsup",
    "build:watch": "tsup src/index.ts --config tsup.config.ts --watch",
    "start": "npm run build:watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist",
    "yalc:pub": "npm run build && yalc publish",
    "dev:yalc": "npm run yalc:pub && tsup src/index.ts --config tsup.config.ts --watch --onSuccess \"yalc publish --push\""
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.563.0",
    "react-chartjs-2": "^5.3.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@swc/core": "^1.15.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "postcss-cli": "^11.0.1",
    "rimraf": "^6.0.0",
    "tailwindcss": "^4.2.1",
    "ts-jest": "^29.1.1",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": [
    "*.css"
  ]
}

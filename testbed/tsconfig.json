{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/lib/*": ["../library/src/*"],                    // Library components
      "@/lib": ["../library/src"],                        // Library root
      "@/components": ["../library/src/components"],       // Direct to library components
      "@/components/*": ["../library/src/components/*"],   // Individual library components
      "@/*": ["./src/*"]                                   // Testbed's own files
    },
    "target": "ES2020",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
# GitHub Packages registry for @mahatisystems scope
@sanjeet-mahati:registry=https://npm.pkg.github.com

# Authentication token — set via environment variable or replace with your PAT.
# For local publishing: export NODE_AUTH_TOKEN=<your_github_pat>
# For CI: this is injected automatically by the GitHub Actions setup-node action.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2017",
    "jsx": "preserve",
    "esModuleInterop": true,
    "strict": true,
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@/components": ["./packages/uicomponents/src"]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "noEmit": true,
    "incremental": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],
  "exclude": [
    "node_modules"
  ]
}

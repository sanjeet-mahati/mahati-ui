{
  "name": "@mahatisystems/mahati-ui-components",
  "version": "4.0.2",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:js": "tsup src/index.ts --config tsup.config.ts",
    "build": "npm run build:js",
    "build:watch": "tsup src/index.ts --config tsup.config.ts --watch",
    "start": "npm run build:watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "clean": "rimraf dist",
    "yalc:pub": "npm run build && yalc publish",
    "dev:yalc": "npm run yalc:pub && tsup src/index.ts --config tsup.config.ts --watch --onSuccess \"yalc publish --push\""
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tooltip": "^1.0.7",
    "chart.js": "^4.5.1",
    "lucide-react": "^0.563.0",
    "react-chartjs-2": "^5.3.1",
    "react-icons": "^5.5.0"
  },
  "devDependencies": {
    "@emotion/babel-plugin": "^11.13.5",
    "@swc/core": "^1.15.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.0.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.0.0",
    "eslint-plugin-react-hooks": "^7.0.0",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "rimraf": "^6.0.0",
    "ts-jest": "^29.4.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "sideEffects": false
}
